      ]
    },
    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "template": "if (this._delayOnce_done === undefined) { this._delayOnce_counter = 0; this._delayOnce_done = false; } if (!this._delayOnce_done) { this._delayOnce_counter++; if (this._delayOnce_counter >= {{frames}}) { this._delayOnce_done = true; {{body}} } }"
    }
