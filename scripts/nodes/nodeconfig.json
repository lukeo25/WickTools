        "gotoAndPlay": "try { gotoAndPlay({{frame}}); } catch(e3) {}",
        "gotoNextFrame": "try { gotoNextFrame(); } catch(e4) {}",
        "gotoPrevFrame": "try { gotoPrevFrame(); } catch(e5) {}"
      },
      "actionKey": "action"
    }
  },
