        {
          "type": "select",
          "key": "fn",
          "label": "function",
          "default": "abs",
          "options": [
            { "value": "abs", "label": "abs" },
            { "value": "floor", "label": "floor" },
            { "value": "ceil", "label": "ceil" },
            { "value": "round", "label": "round" },
            { "value": "sqrt", "label": "sqrt" },
            { "value": "sin", "label": "sin" },
            { "value": "cos", "label": "cos" },
            { "value": "tan", "label": "tan" },
            { "value": "min", "label": "min" },
            { "value": "max", "label": "max" },
            { "value": "pow", "label": "pow" }
          ]
        },
        { "type": "text", "key": "a", "label": "a", "default": "0" },
        { "type": "text", "key": "b", "label": "b", "default": "0", "showWhen": { "key": "fn", "in": ["min", "max", "pow"] } }
      ]
    },
    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "templateByAction": {
        "abs": "{{scope}}.{{out}} = Math.abs({{a}});",
        "floor": "{{scope}}.{{out}} = Math.floor({{a}});",
        "ceil": "{{scope}}.{{out}} = Math.ceil({{a}});",
        "round": "{{scope}}.{{out}} = Math.round({{a}});",
        "sqrt": "{{scope}}.{{out}} = Math.sqrt({{a}});",
        "sin": "{{scope}}.{{out}} = Math.sin({{a}});",
        "cos": "{{scope}}.{{out}} = Math.cos({{a}});",
        "tan": "{{scope}}.{{out}} = Math.tan({{a}});",
        "min": "{{scope}}.{{out}} = Math.min({{a}}, {{b}});",
        "max": "{{scope}}.{{out}} = Math.max({{a}}, {{b}});",
        "pow": "{{scope}}.{{out}} = Math.pow({{a}}, {{b}});"
      },
      "actionKey": "fn"
    }
  },
  {
    "id": "clamp",
    "label": "Clamp",
    "kind": "ScriptNode",
    "category": "Logic",
    "ports": {
