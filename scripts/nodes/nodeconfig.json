  {
    "id": "boundsContainsPoint",
    "label": "Bounds Contains Point",
    "kind": "ScriptNode",
    "category": "Conditions",
    "ports": {
      "inputs": ["trigger"],
      "outputs": ["code"]
    },
    "ui": {
