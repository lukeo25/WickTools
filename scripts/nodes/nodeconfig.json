  {
    "id": "everyNFrames",
    "label": "Every N Frames",
    "kind": "ScriptNode",
    "category": "Timing",
    "ports": {
      "inputs": ["trigger"],
      "outputs": ["code"]
    },
    "ui": {
      "controls": [
        { "type": "number", "key": "n", "label": "frames", "default": 10, "min": 1, "step": 1 },
        { "type": "text", "key": "body", "label": "code", "default": "/* add code */" }
      ]
    },
    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "template": "if (!this._everyN_counter) this._everyN_counter = 0; this._everyN_counter++; if (this._everyN_counter >= {{n}}) { this._everyN_counter = 0; {{body}} }"
    }
  },
  {
    "id": "delayOnce",
    "label": "Delay Once",
    "kind": "ScriptNode",
