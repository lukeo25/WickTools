  {
    "id": "timelineControl",
    "label": "Timeline",
    "kind": "ScriptNode",
    "category": "Playback",
    "ports": {
      "inputs": [
        "trigger"
      ],
      "outputs": [
        "code"
      ]
    },
    "ui": {
      "controls": [
        {
          "type": "select",
          "key": "action",
          "label": "action",
          "default": "stop",
          "options": [
            {
              "value": "stop",
              "label": "stop"
            },
            {
              "value": "play",
              "label": "play"
            },
            {
              "value": "gotoAndStop",
              "label": "gotoAndStop"
            },
            {
              "value": "gotoAndPlay",
              "label": "gotoAndPlay"
            },
            {
              "value": "gotoNextFrame",
              "label": "gotoNextFrame"
            },
            {
              "value": "gotoPrevFrame",
              "label": "gotoPrevFrame"
            }
          ]
        },
        {
          "type": "number",
          "key": "frame",
          "label": "frame",
          "default": 1,
          "step": 1,
          "min": 1,
          "showWhen": {
            "key": "action",
            "in": [
              "gotoAndStop",
              "gotoAndPlay"
            ]
          }
        }
      ]
    },
    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "templateByAction": {
        "stop": "try { if (this && this.stop) this.stop(); } catch(e0) {}",
        "play": "try { if (this && this.play) this.play(); } catch(e1) {}",
        "gotoAndStop": "try { if (this && this.gotoAndStop) this.gotoAndStop({{frame}}); } catch(e2) {}",
        "gotoAndPlay": "try { if (this && this.gotoAndPlay) this.gotoAndPlay({{frame}}); } catch(e3) {}",
        "gotoNextFrame": "try { if (this && this.gotoNextFrame) this.gotoNextFrame(); } catch(e4) {}",
        "gotoPrevFrame": "try { if (this && this.gotoPrevFrame) this.gotoPrevFrame(); } catch(e5) {}"
      }
    }
  },
  {
    "id": "globalTimeline",
    "label": "Global Timeline",
    "kind": "ScriptNode",
    "category": "Playback",
    "ports": {
      "inputs": [
        "trigger"
      ],
      "outputs": [
        "code"
      ]
    },
    "ui": {
      "controls": [
        {
          "type": "select",
          "key": "action",
          "label": "action",
          "default": "gotoAndStop",
          "options": [
            {
              "value": "gotoAndStop",
              "label": "gotoAndStop"
            },
            {
              "value": "gotoAndPlay",
              "label": "gotoAndPlay"
            },
            {
              "value": "gotoNextFrame",
              "label": "gotoNextFrame"
            },
            {
              "value": "gotoPrevFrame",
              "label": "gotoPrevFrame"
            },
            {
              "value": "play",
              "label": "play"
            },
            {
              "value": "stop",
              "label": "stop"
            }
          ]
        },
        {
          "type": "number",
          "key": "frame",
          "label": "frame",
          "default": 1,
          "step": 1,
          "min": 1,
          "showWhen": {
            "key": "action",
            "in": [
              "gotoAndStop",
              "gotoAndPlay"
            ]
          }
        }
      ]
    },
    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "templateByAction": {
        "gotoAndStop": "try { gotoAndStop({{frame}}); } catch(e0) {}",
        "gotoAndPlay": "try { gotoAndPlay({{frame}}); } catch(e1) {}",
        "gotoNextFrame": "try { gotoNextFrame(); } catch(e2) {}",
        "gotoPrevFrame": "try { gotoPrevFrame(); } catch(e3) {}",
        "play": "try { play(); } catch(e4) {}",
        "stop": "try { stop(); } catch(e5) {}"
      }
    }
  },
