    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "template": "if ({{scope}}.{{varname}} === undefined) {{scope}}.{{varname}} = 0; {{scope}}.{{varname}} {{op}} {{value}};"
    }
