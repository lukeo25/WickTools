[
  {
    "id": "timelineControl",
    "label": "Timeline",
    "kind": "ScriptNode",
    "category": "Playback",
    "ports": {
      "inputs": ["trigger"],
      "outputs": ["code"]
    },
    "ui": {
      "controls": [
        {
          "type": "select",
          "key": "action",
          "label": "action",
          "default": "stop",
          "options": [
            { "value": "stop", "label": "stop" },
            { "value": "play", "label": "play" },
            { "value": "gotoAndStop", "label": "gotoAndStop" },
            { "value": "gotoAndPlay", "label": "gotoAndPlay" },
            { "value": "gotoNextFrame", "label": "gotoNextFrame" },
            { "value": "gotoPrevFrame", "label": "gotoPrevFrame" }
          ]
        },
        {
          "type": "text",
          "key": "frame",
          "label": "frame",
          "default": "1",
          "showWhen": { "key": "action", "in": ["gotoAndStop", "gotoAndPlay"] }
        }
      ]
    },
    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "templateByAction": {
        "stop": "if (this && this.stop) this.stop();",
        "play": "if (this && this.play) this.play();",
        "gotoAndStop": "try { if (this && this.gotoAndStop) this.gotoAndStop({{frame}}); } catch(e0) {}",
        "gotoAndPlay": "try { if (this && this.gotoAndPlay) this.gotoAndPlay({{frame}}); } catch(e1) {}",
        "gotoNextFrame": "try { if (this && this.gotoNextFrame) this.gotoNextFrame(); } catch(e2) {}",
        "gotoPrevFrame": "try { if (this && this.gotoPrevFrame) this.gotoPrevFrame(); } catch(e3) {}"
      },
      "actionKey": "action"
    }
  },
