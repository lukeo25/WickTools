  {
    "id": "varSet",
    "label": "Set Variable",
    "kind": "ScriptNode",
    "category": "Logic",
    "ports": {
      "inputs": [
        "trigger"
      ],
      "outputs": [
        "code"
      ]
    },
    "ui": {
      "controls": [
        {
          "type": "select",
          "key": "scope",
          "label": "scope",
          "default": "this",
          "options": [
            {
              "value": "this",
              "label": "this clip"
            },
            {
              "value": "project",
              "label": "project global"
            }
          ]
        },
        {
          "type": "text",
          "key": "varname",
          "label": "var",
          "default": "myVar"
        },
        {
          "type": "select",
          "key": "valtype",
          "label": "type",
          "default": "number",
          "options": [
            {
              "value": "number",
              "label": "number"
            },
            {
              "value": "text",
              "label": "text"
            },
            {
              "value": "bool",
              "label": "bool"
            },
            {
              "value": "randomInt",
              "label": "random int"
            },
            {
              "value": "randomFloat",
              "label": "random float"
            }
          ]
        },
        {
          "type": "text",
          "key": "value",
          "label": "value",
          "default": "0",
          "showWhen": {
            "key": "valtype",
            "in": [
              "number",
              "text",
              "bool"
            ]
          }
        },
        {
          "type": "text",
          "key": "rmin",
          "label": "min",
          "default": "0",
          "showWhen": {
            "key": "valtype",
            "in": [
              "randomInt",
              "randomFloat"
            ]
          }
        },
        {
          "type": "text",
          "key": "rmax",
          "label": "max",
          "default": "10",
          "showWhen": {
            "key": "valtype",
            "in": [
              "randomInt",
              "randomFloat"
            ]
          }
        }
      ]
    },
    "script": {
      "slotDefault": "update",
      "slotMode": "byTargetPort",
      "templateByAction": {
        "number": "{{scope}}.{{varname}} = {{value}};",
        "text": "{{scope}}.{{varname}} = '{{value}}';",
        "bool": "{{scope}}.{{varname}} = ({{value}}) ? true : false;",
        "randomInt": "{{scope}}.{{varname}} = random.integer({{rmin}}, {{rmax}});",
        "randomFloat": "{{scope}}.{{varname}} = random.float({{rmin}}, {{rmax}});"
      },
      "actionKey": "valtype"
    }
  },
